# ==========================================
# Feed Generator Configuration
# ==========================================

# Hostname pubblico del server (es. tuo-dominio.com)
FEEDGEN_HOSTNAME=localhost

# Porta del server HTTP
FEEDGEN_PORT=8080

# Host per bindare (0.0.0.0 per accettare connessioni esterne)
FEEDGEN_LISTENHOST=0.0.0.0

# Service DID (identificativo decentralizzato)
# Formato: did:web:tuo-dominio.com oppure did:plc:xxx
FEEDGEN_SERVICE_DID=did:web:localhost

# DID del publisher (il TUO DID Bluesky)
# OBBLIGATORIO: Ottieni il tuo DID da bsky.app/settings
FEEDGEN_PUBLISHER_DID=did:plc:YOUR_DID_HERE

# ==========================================
# Web App Configuration
# ==========================================

# Chiave segreta per le sessioni (almeno 16 caratteri)
# GENERA UNA CHIAVE SICURA: openssl rand -hex 32
SESSION_KEY=change-this-to-a-secure-random-string

# ==========================================
# Bluesky Configuration (Opzionale)
# ==========================================

# Handle Bluesky (solo per testing)
BSKY_HANDLE=your-handle.bsky.social

# App Password (solo per testing)
# Genera da: bsky.app/settings/app-passwords
BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ==========================================
# Note
# ==========================================
# 
# Per produzione:
# 1. Imposta FEEDGEN_HOSTNAME al tuo dominio pubblico
# 2. Imposta FEEDGEN_PUBLISHER_DID al tuo DID Bluesky
# 3. Genera una SESSION_KEY sicura
# 4. NON committare questo file con valori reali
#
# Per sviluppo locale:
# 1. Mantieni FEEDGEN_HOSTNAME=localhost
# 2. Imposta FEEDGEN_PUBLISHER_DID al tuo DID
# 3. Usa una SESSION_KEY di test